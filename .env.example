# ──────────────────────────────────────────────────────────────────────────
# Signal — environment variables for the COLLECTOR (npm run collect).
#
# The deployed dashboard (Vercel) needs NONE of these — it only reads
# data/mentions.json. Add these as GitHub repository Secrets so the scheduled
# Action can refresh the data. Each source degrades gracefully: leave a key
# blank and that source is skipped.
# ──────────────────────────────────────────────────────────────────────────

# REQUIRED — Reddit posts/comments via Apify (no Reddit API needed).
# Token: apify.com → Settings → Integrations → API tokens.
APIFY_TOKEN=

# OPTIONAL — one Google key powers Custom Search (web/forums/Reddit) + YouTube.
# console.cloud.google.com (enable "Custom Search API" + "YouTube Data API v3")
# and programmablesearchengine.google.com for the cx id ("Search entire web").
GOOGLE_API_KEY=
YOUTUBE_API_KEY=        # usually the same value as GOOGLE_API_KEY
GOOGLE_CSE_ID=

# OPTIONAL — Groq for tailored draft replies. https://console.groq.com
# Without it, the collector uses a templated fallback (no per-thread drafts).
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
