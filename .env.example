# ──────────────────────────────────────────────────────────────────────────
# Signal — environment variables for the COLLECTOR (npm run collect).
#
# The deployed dashboard (Vercel) needs NONE of these — it only reads
# data/mentions.json. Add these as GitHub repository Secrets so the scheduled
# Action can refresh the data. Each source degrades gracefully: leave a key
# blank and that source is skipped.
# ──────────────────────────────────────────────────────────────────────────

# REQUIRED — Reddit posts/comments via Apify (no Reddit API needed).
# Token: apify.com → Settings → Integrations → API tokens.
APIFY_TOKEN=

# OPTIONAL — one Google key powers Custom Search (web/forums/Reddit) + YouTube.
# console.cloud.google.com (enable "Custom Search API" + "YouTube Data API v3")
# and programmablesearchengine.google.com for the cx id ("Search entire web").
GOOGLE_API_KEY=
YOUTUBE_API_KEY=        # usually the same value as GOOGLE_API_KEY
GOOGLE_CSE_ID=

# RECOMMENDED — Azure AI Foundry for classification, themes, sentiment, and
# tailored draft replies. (Falls back to Groq, then keyword heuristics.)
AZURE_AI_API_KEY=
AZURE_AI_ENDPOINT=          # e.g. https://your-resource.services.ai.azure.com/
AZURE_AI_DEPLOYMENT=gpt-4o-mini
AZURE_AI_API_VERSION=2024-08-01-preview

# OPTIONAL — Groq as an alternative LLM. https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# VERCEL ONLY — lets the dashboard's Settings panel save tracking-list changes
# by committing data/config.json to the repo. Create a fine-grained GitHub PAT
# with Contents: Read & write on this repo. Not needed in GitHub Actions.
GITHUB_TOKEN=
GITHUB_REPO=ashpai2504/Signal-Hunter
